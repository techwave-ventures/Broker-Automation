# Auth bypass (development only)
# Set to 'true' to skip authentication/JWT validation during local development. When enabled,
# the app uses TP_CONTACT_EMAIL as the user identity instead of verifying JWT.
# This is ignored in production (NODE_ENV !== 'development').
# BYPASS_AUTH='true'

# JWT Authentication Configuration
# Generate a secure random JWT secret key (minimum 32 characters suggested)
JWT_SECRET='super-secret-jwt-key-for-broker-automation-32bytes!'
APP_BASE_URL='http://localhost:3000'

# Meta / Facebook Configuration
# Get these values from the Meta Developer Dashboard: https://developers.facebook.com/apps/
FB_APP_ID='your-facebook-app-id'
FB_APP_SECRET='your-facebook-app-secret'
FB_GRAPH_API_VERSION='v22.0'
FB_REG_PIN='your-registration-pin'
FB_VERIFY_TOKEN='your-webhook-verify-token'

# Ably & Redis Configuration
# Get this from your Ably dashboard: https://ably.com/accounts
ABLY_KEY='your-ably-api-key'
REDIS_URL='redis://localhost:6379'

# Contact Information
TP_CONTACT_EMAIL='your-contact-email@example.com'

# Privacy Policy (optional)
# If set to an http(s) URL, the /privacy route redirects there. Leave unset (or
# set to any non-URL value) to serve the built-in placeholder page at /privacy.
# PRIVACY_POLICY_URL='https://example.com/privacy'

# Database (auto-configured when using Vercel + Neon integration)
POSTGRES_URL='postgres://...'

# GCP Vertex AI Configuration (for Gemini Auto-Reply Agent using GCP credentials)
GCP_PROJECT_ID='your-gcp-project-id'
GCP_LOCATION='us-central1'
# Optional: absolute path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=''
# Optional: inline service account JSON key contents (stringified JSON on a single line)
GCP_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "your-gcp-project-id", "private_key": "-----BEGIN PRIVATE KEY-----\\n...", "client_email": "your-service-account@your-gcp-project-id.iam.gserviceaccount.com"}'

# Note: Copy this file to .env.local and replace the placeholder values with your actual secrets.
# Never commit .env.local to version control.
