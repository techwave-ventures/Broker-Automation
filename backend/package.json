{
  "name": "business-messaging-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:once": "tsx src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "concurrently -k \"node dist/server.js\" \"node dist/worker.js\"",
    "worker:start": "node dist/worker.js",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ably": "^2.12.0",
    "bullmq": "^5.80.8",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.1.0",
    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
