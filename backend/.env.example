PORT=3001
NODE_ENV=development

POSTGRES_URL=postgres://user:password@localhost:5432/database
APP_BASE_URL=http://localhost:3000

# Authentication & JWT Configuration
# Generate a secure random JWT secret key (minimum 32 characters suggested)
JWT_SECRET=super-secret-jwt-key-for-broker-automation-32bytes!
BYPASS_AUTH=false
TP_CONTACT_EMAIL=dev@example.com

# Meta / Facebook Configuration
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
FB_GRAPH_API_VERSION=v22.0
FB_REG_PIN=your-registration-pin
FB_VERIFY_TOKEN=your-webhook-verify-token

# Ably & Redis Configuration
ABLY_KEY=your-ably-api-key
REDIS_URL=redis://localhost:6379

# Database verification script configuration
TEST_USER_EMAIL=xyz@gmail.com

# GCP Vertex AI Configuration (for Gemini Auto-Reply Agent using GCP credits)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Optional: absolute path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: inline service account JSON key contents (stringified JSON on a single line)
GCP_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "your-gcp-project-id", "private_key": "-----BEGIN PRIVATE KEY-----\\n...", "client_email": "your-service-account@your-gcp-project-id.iam.gserviceaccount.com"}'
